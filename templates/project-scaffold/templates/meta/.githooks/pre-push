#!/usr/bin/env bash
# Canon trunk-root guard (pre-push) — backstop for the pre-commit guard.
# Refuses a push that would land a commit on a protected branch without it having gone
# through another branch (a merge) — i.e. a commit reachable from no other ref, the lens-meta
# definition of a direct-to-trunk commit. A proper feature-branch merge passes; a deletion passes.
# Args: $1 remote name, $2 remote url. Stdin: <local ref> <local sha> <remote ref> <remote sha>.
set -euo pipefail

PROTECTED="${TRON_PROTECTED_BRANCHES:-main staging}"
ZERO="0000000000000000000000000000000000000000"

while read -r _local_ref local_sha remote_ref remote_sha; do
  for pat in $PROTECTED; do
    case "$remote_ref" in
      refs/heads/$pat) ;;
      *) continue ;;
    esac
    [ "$local_sha" = "$ZERO" ] && continue          # branch deletion — allowed
    target="${remote_ref#refs/heads/}"
    if [ "$remote_sha" = "$ZERO" ]; then
      range="$local_sha"                            # new protected branch — inspect all of it
    else
      range="$remote_sha..$local_sha"
    fi
    # Merge commits are how reviewed work lands on trunk — allow them (--no-merges skips them).
    # A NON-merge commit on trunk that no other branch contains was authored directly on trunk.
    for c in $(git rev-list --no-merges "$range" 2>/dev/null || true); do
      others="$(git branch --contains "$c" 2>/dev/null | sed 's/^[* ]*//' | grep -vx "$target" || true)"
      if [ -z "$others" ]; then
        echo "✗ trunk-root guard: refusing direct push to '$target'." >&2
        echo "  Commit ${c:0:9} was authored on trunk, not merged from a branch. Use a PR instead." >&2
        exit 1
      fi
    done
  done
done
exit 0
